{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "FLUX",
    "scopeName": "source.flux",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#constants" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.flux",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.flux",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flux",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.flux",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flux",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.flux",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.flux",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flux",
                    "match": "\\b(?i:PRINT|ASK|DEF|RETURN|IF|ELIF|ELSE|FOR|IN|WHILE|CLASS|INIT|IMPORT|FROM|AS|TRY|EXCEPT|FINALLY|RAISE|ASYNC|AWAIT|BREAK|CONTINUE|PASS|RANGE|TYPE)\\b"
                },
                {
                    "name": "keyword.operator.logical.flux",
                    "match": "\\b(?i:AND|OR|NOT)\\b"
                },
                {
                    "name": "variable.language.flux",
                    "match": "\\b(?i:SELF)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.flux",
                    "match": "\\b(?i:TRUE|FALSE|NONE)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.flux",
                    "match": "(==|!=|<=|>=|\\*\\*|//|[+\\-*/%<>=:])"
                }
            ]
        }
    }
}
